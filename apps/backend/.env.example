NODE_ENV=development
PORT=5000

# Database
# Atlas format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
# Local format: mongodb://localhost:27017/vedaai
# IMPORTANT: Do NOT wrap the password in < > angle brackets — those break auth with code 8000!
MONGODB_URI=mongodb://localhost:27017/vedaai

# Redis
# Local: redis://localhost:6379
# Upstash (TLS): rediss://default:YOUR_PASSWORD@your-endpoint.upstash.io:6379
# IMPORTANT: Do NOT prefix with "redis-cli --tls -u" — just use the URL directly
# WARNING: Upstash serverless Redis does NOT support BLPOP/blocking commands required by BullMQ.
#          BullMQ workers WILL NOT PROCESS JOBS with Upstash. Use a real Redis instance instead.
REDIS_URL=redis://localhost:6379
REDIS_BULLMQ_URL=redis://localhost:6379

# AI Providers (add keys for providers you want to use — at least one required for generation)
# NVIDIA and Groq are the primary provider pair. Anthropic is a fallback.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
NVIDIA_API_KEY=nvapi-...
GROQ_API_KEY=gsk_...

# Security
JWT_SECRET=change-this-to-a-long-random-string-in-production

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# Local development resource controls
# Set ENABLE_BACKGROUND_WORKERS=false if you only need the API/UI and want to save memory.
ENABLE_BACKGROUND_WORKERS=true
AI_WORKER_CONCURRENCY=1
PDF_WORKER_CONCURRENCY=1
QUEUE_SWEEP_INTERVAL_MS=120000
STALL_MONITOR_INTERVAL_MS=300000
