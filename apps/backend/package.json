{
  "name": "vedaai-backend",
  "version": "1.0.0",
  "description": "VedaAI Backend API Server",
  "main": "dist/app.js",
  "scripts": {
    "dev": "node --max-old-space-size=512 ../../node_modules/ts-node-dev/lib/bin.js --respawn --transpile-only --ignore-watch node_modules --ignore-watch dist --ignore-watch uploads src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:connections": "ts-node-dev --transpile-only --exit-child src/scripts/test-connections.ts",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.18.0",
    "@google/generative-ai": "^0.3.1",
    "@sparticuz/chromium": "^123.0.0",
    "bullmq": "^5.3.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.18.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.2.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonrepair": "^3.14.0",
    "mongoose": "^8.24.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.28.0",
    "pdf-parse": "^1.1.1",
    "puppeteer-core": "^22.3.0",
    "socket.io": "^4.7.4",
    "uuid": "^9.0.1",
    "winston": "^3.12.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.24",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^7.2.0",
    "@typescript-eslint/parser": "^7.2.0",
    "eslint": "^8.57.0",
    "supertest": "^6.3.4",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2",
    "vitest": "^4.1.7"
  }
}
